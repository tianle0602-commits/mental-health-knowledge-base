    coverImage: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=A%20thought-provoking%20illustration%20of%20a%20person%20holding%20multiple%20subtle%20masks%20in%20front%20of%20their%20face,%20with%20warm%20authentic%20light%20emerging%20from%20behind,%20Jungian%20persona%20theme&image_size=landscape_4_3',
    keyConcept: {
